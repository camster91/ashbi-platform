    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "fastify": "^5.1.0",
    "form-data": "^4.0.0",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.460.0",
    "mailgun.js": "^10.2.2",
    "mailparser": "^3.7.1",
