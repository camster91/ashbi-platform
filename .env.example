# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
# AI_PROVIDER: 'claude' (default) or 'gemini' - which AI model to use
AI_PROVIDER=claude

# Redis (for queues)
REDIS_URL=redis://localhost:6379

# Email webhook secret (validate incoming)
WEBHOOK_SECRET=your-webhook-secret

# Mailgun
MAILGUN_SIGNING_KEY=your-mailgun-signing-key

# Bot API
BOT_SECRET=your-bot-secret

# Outreach Agent — Hunter.io
HUNTER_API_KEY=your-hunter-api-key

# Outreach Agent — Mailgun (sending)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain

# Blog Agent — WordPress publishing
ASHBI_WP_URL=https://ashbi.ca
ASHBI_WP_USER=your-wordpress-username
ASHBI_WP_APP_PASSWORD=your-wordpress-app-password

# ─── Command Center Integrations ───────────────────────────────────────────────

# GitHub Integration
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_ORG=camster91

# Coolify / VPS
COOLIFY_URL=http://187.77.26.99:8000
COOLIFY_TOKEN=your-coolify-api-token

# Notion Sync
NOTION_TOKEN=your-notion-integration-token

# Hostinger site monitoring (comma-separated domains)
