# Database (PostgreSQL with pgvector required)
DATABASE_URL=postgresql://ashbihub:password@localhost:5432/ashbihub

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=https://hub.ashbi.ca

# Auth
JWT_SECRET=your-secret-key-change-in-production

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
# AI_PROVIDER: 'ollama' (default), 'claude', or 'gemini'
AI_PROVIDER=ollama
OLLAMA_API_KEY=your-ollama-cloud-api-key
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b
# Kilo AI Gateway
KILO_API_KEY=your-kilo-api-key
KILO_API_BASE=https://api.kilo.ai/api/gateway/
KILO_MODEL=anthropic/claude-haiku-4-5

# Redis (for BullMQ queues)
REDIS_URL=redis://localhost:6379

# Webhook
WEBHOOK_SECRET=your-webhook-secret

# Credentials vault encryption key
CREDENTIALS_KEY=your-credentials-encryption-key

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=ashbi.ca
MAILGUN_SIGNING_KEY=your-mailgun-signing-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Shopify
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret

# Bot API
BOT_SECRET=your-bot-secret

# Notification webhook
NOTIFICATION_WEBHOOK_URL=

# App URLs
APP_URL=https://hub.ashbi.ca
HUB_URL=https://hub.ashbi.ca
PORTAL_BASE_URL=https://hub.ashbi.ca

# Outreach Agent — Hunter.io
HUNTER_API_KEY=your-hunter-api-key

# Blog Agent — WordPress publishing
ASHBI_WP_URL=https://ashbi.ca
ASHBI_WP_USER=your-wordpress-username
ASHBI_WP_APP_PASSWORD=your-wordpress-app-password

# Command Center Integrations
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_ORG=camster91
COOLIFY_URL=http://187.77.26.99:8000
COOLIFY_TOKEN=your-coolify-api-token
NOTION_TOKEN=your-notion-integration-token
HOSTINGER_ASHBI_SITES=ashbi.ca,ashbidesign.com
HOSTINGER_INFLUENCER_STORES=store1.com,store2.com

# OpenClaw
OPENCLAW_URL=http://localhost:3000
OPENCLAW_API_KEY=your-openclaw-api-key

# Frontend
VITE_API_URL=