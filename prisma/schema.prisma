  publishedAt DateTime?
  contentUrl  String? // URL of published content
  clientId    String?
  projectId   String?
  assigneeId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client   Client?  @relation(fields: [clientId], references: [id])
  project  Project? @relation(fields: [projectId], references: [id])
  assignee User?    @relation("CalendarEventAssignee", fields: [assigneeId], references: [id])

  @@index([scheduledAt])
  @@map("content_calendar_events")
}

// ==================== SEO AUDITS (from ashbi-hub) ====================

model SEOAudit {
  id          String   @id @default(cuid())
  url         String
  title       String? // Page title
  score       Int      @default(0) // 0-100
  issues      String   @default("[]") // JSON: array of issue objects
  suggestions String   @default("[]") // JSON: array of suggestion objects
  keywords    String   @default("[]") // JSON: target keywords
  clientId    String?
  projectId   String?
  status      String   @default("PENDING") // PENDING | COMPLETED | FAILED
  aiGenerated Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client  Client?  @relation(fields: [clientId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@map("seo_audits")
}

// ==================== SNIPPET LIBRARY (from ashbi-hub) ====================

model Snippet {
  id          String   @id @default(cuid())
  title       String
  description String?
  code        String   @db.Text
  language    String   @default("javascript")
  category    String   @default("general") // general | react | css | sql | api | utility
  tags        String   @default("[]") // JSON: array of tag strings
  isFavorite  Boolean  @default(false)
  useCount    Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id])

  @@map("snippets")
}

// ==================== ASSET LIBRARY (from ashbi-hub) ====================

model Asset {
  id           String   @id @default(cuid())
  name         String
  type         String   @default("IMAGE") // IMAGE | VIDEO | FONT | ICON | DOCUMENT | TEMPLATE
  url          String
  thumbnailUrl String?
  size         Int? // File size in bytes
  mimeType     String?
  altText      String?
  tags         String   @default("[]") // JSON: array of tag strings
  clientId     String?
  folderId     String? // For nested folder structure
  isGlobal     Boolean  @default(false) // Available to all clients vs client-specific
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id])

  @@map("assets")
}

// ==================== CLIENT EMBEDDINGS (RAG / Client Brain) ====================

model ClientEmbedding {
  id        String                      @id @default(cuid())
  clientId  String
  source    String // EMAIL | NOTE | CALL | INVOICE | PROPOSAL | PROJECT | MANUAL
  sourceId  String? // ID of the source record
  content   String                      @db.Text // The text content that was embedded
  embedding Unsupported("vector(768)")? // pgvector embedding
  metadata  String                      @default("{}") // JSON: additional context
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([source])
  @@map("client_embeddings")
}

// ==================== TIME SESSIONS (from ashbi-hub) ====================

model TimeSession {
  id          String    @id @default(cuid())
  userId      String
  projectId   String
  taskId      String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int       @default(0) // Duration in minutes (calculated on stop)
  description String?
  billable    Boolean   @default(true)
  isRunning   Boolean   @default(false) // True if timer is currently running
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([isRunning])
  @@map("time_sessions")
}

// ==================== PROMPT VERSIONS (for AI enhancement) ====================

model PromptVersion {
  id          String   @id @default(cuid())
  name        String // e.g., "analyzeMessage", "draftResponse"
  version     Int      @default(1)
  system      String   @db.Text // System prompt
  template    String   @db.Text // Prompt template with {{variables}}
  temperature Float    @default(0.7)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, version])
  @@map("prompt_versions")
}

model ClientInvitation {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  clientId  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@map("client_invitations")
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique
  userId     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("api_keys")
}

// ==================== ESTIMATES ====================

model Estimate {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String   @default("DRAFT") // DRAFT, SENT, APPROVED, DECLINED, CONVERTED
  lineItems   Json     @default("[]") // [{description, quantity, rate, amount}]
  subtotal    Float    @default(0)
  tax         Float    @default(0)
  total       Float    @default(0)
  validUntil  DateTime?
  viewToken   String   @unique @default(cuid())
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@map("estimates")
}

model RateCard {
  id          String   @id @default(cuid())
  name        String
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rates       Json     @default("[]") // [{serviceName, unit, rate, description}]
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("rate_cards")
}

model Integration {
  id           String    @id @default(cuid())
  type         String    // QUICKBOOKS, XERO
  accessToken  String?
  refreshToken String?
  orgId        String?
  status       String    @default("DISCONNECTED") // CONNECTED, DISCONNECTED, ERROR
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("integrations")
}
